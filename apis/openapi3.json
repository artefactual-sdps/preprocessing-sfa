              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatusResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatusResult"
                }
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatusResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatusResult"
