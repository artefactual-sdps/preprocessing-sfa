    "/api/ImportTasks": {
      "post": {
        "tags": [
          "ImportTasks"
        ],
        "summary": "Creates a new import task.",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file",
                  "sipType",
                  "username"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "The metadata.xml file according to eCH-0160",
                    "format": "binary"
                  },
                  "sipType": {
                    "$ref": "#/components/schemas/SipType"
                  },
                  "username": {
                    "type": "string",
                    "description": "The username that is logged as the creator of the import task. Can be the email for example."
                  }
                }
              },
              "encoding": {
                "file": {
                  "style": "form"
                },
                "sipType": {
                  "style": "form"
                },
                "username": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateImportTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateImportTaskResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "415": {
            "description": "Unsupported Media Type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateImportTaskResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateImportTaskResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/ImportTasks/{id}/status": {
      "get": {
        "tags": [
          "ImportTasks"
        ],
        "summary": "Query the status of an ongoing analysis or import",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The id of the import task to query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportTaskStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/ImportTasks/{id}": {
      "patch": {
        "tags": [
          "ImportTasks"
        ],
        "summary": "Updates the status of an existing import task.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The unique identifier of the import task to be updated.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "The request containing the new status and related details for the import task. Only the status Evelix.Apis.Contract.Common.Entities.CodeValues.ImportTaskStatus.Abgebrochen is allowed.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelImportTaskRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelImportTaskRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CancelImportTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The import task was successfully updated.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ImportTaskDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportTaskDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportTaskDto"
                }
              }
            }
          },
          "409": {
            "description": "The requested status transition is not allowed.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "The specified import task was not found.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/ImportTasks/{id}/importRuns": {
      "post": {
        "tags": [
          "ImportTasks"
        ],
        "summary": "Starts a new import run for the given import task.\r\nCreates a new import execution (\"run\") resource.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ImportTask identifier.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "The METS file required for the import.\r\n(To be decided: Or a zip file containing the METS and the metadata.xml file?))",
                    "format": "binary"
                  },
                  "importBehaviour": {
                    "$ref": "#/components/schemas/ImportBehaviourType"
                  }
                }
              },
              "encoding": {
                "file": {
                  "style": "form"
                },
                "importBehaviour": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/CreateImportRunResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateImportRunResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateImportRunResponse"
