              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatusResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatusResult"
                }
              },
              "text/json": {
                "schema": {
